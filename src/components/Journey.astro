---

---

<section class="journey-section section">
  <div class="container">
    <div class="journey-header">
      <h2 class="section-title">Empowering Your <em>Financial Journey</em></h2>
      <p class="section-desc" style="text-align:center;margin:16px auto 0;max-width:520px;">
        Our platform combines cutting-edge technology with seamless user experience to give you control over your finances
      </p>
    </div>

    <div class="journey-grid-top">
      <div class="journey-card journey-card-large">
        <h3 class="journey-card-title">Real-Time Account Monitoring</h3>
        <p class="journey-card-desc">Track all your accounts, transactions, and balances in real-time with a clear, intuitive dashboard.</p>
        <div class="journey-chart">
          <svg viewBox="0 0 400 120" fill="none" class="chart-svg">
            <line x1="40" y1="20" x2="40" y2="100" stroke="#eee" stroke-width="1"/>
            <text x="25" y="25" font-size="10" fill="#999">10K</text>
            <text x="25" y="50" font-size="10" fill="#999">5K</text>
            <text x="25" y="75" font-size="10" fill="#999">2K</text>
            <text x="25" y="100" font-size="10" fill="#999">1K</text>
            <line x1="40" y1="100" x2="380" y2="100" stroke="#eee" stroke-width="1"/>
            <!-- Green line chart -->
            <path d="M50 70 Q80 60 110 50 T170 65 T230 40 T290 55 T350 30 T380 25" stroke="#10b981" stroke-width="2" fill="none"/>
            <path d="M50 70 Q80 60 110 50 T170 65 T230 40 T290 55 T350 30 T380 25 V100 H50Z" fill="url(#greenGrad)" opacity="0.1"/>
            <!-- Red line -->
            <path d="M50 85 Q80 80 110 82 T170 78 T230 85 T290 75 T350 80 T380 82" stroke="#ef4444" stroke-width="2" fill="none"/>
            <defs>
              <linearGradient id="greenGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#10b981"/>
                <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>

      <div class="journey-card journey-card-large">
        <h3 class="journey-card-title">Digital Payments Globally</h3>
        <p class="journey-card-desc">Make fast and secure payments globally with encryption and advanced fraud protection, ensuring your money is always safe.</p>
        <div class="journey-globe">
          <div class="globe-dots">
            <div class="globe-dot" style="top:20%;left:30%;background:#ef4444;"></div>
            <div class="globe-dot" style="top:15%;left:55%;background:#ef4444;"></div>
            <div class="globe-dot" style="top:45%;left:20%;background:#f59e0b;"></div>
            <div class="globe-dot" style="top:55%;left:45%;background:#10b981;"></div>
            <div class="globe-dot" style="top:35%;left:70%;background:#f59e0b;"></div>
            <div class="globe-dot" style="top:65%;left:60%;background:#10b981;"></div>
            <div class="globe-dot" style="top:70%;left:80%;background:#6366f1;"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="journey-grid-bottom">
      <div class="journey-card-sm">
        <h3 class="journey-sm-title">Multi-Currency Wallet</h3>
        <p class="journey-sm-desc">Manage multiple currencies in a single wallet for effortless international transactions</p>
      </div>
      <div class="journey-card-sm">
        <h3 class="journey-sm-title">Instant Loan Approvals</h3>
        <p class="journey-sm-desc">Apply for personal or business loans and get approval within minutes.</p>
      </div>
      <div class="journey-card-sm">
        <h3 class="journey-sm-title">Smart Investment Tools</h3>
        <p class="journey-sm-desc">Access AI-powered investment insights, portfolio tracking to grow your wealth.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .journey-section {
    background: var(--color-white);
  }

  .journey-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .journey-grid-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 28px;
  }

  .journey-card-large {
    background: var(--color-bg-section);
    border-radius: var(--radius-xl);
    padding: 36px;
    min-height: 360px;
    display: flex;
    flex-direction: column;
  }

  .journey-card-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 12px;
  }

  .journey-card-desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 400px;
  }

  .journey-chart {
    flex: 1;
    display: flex;
    align-items: flex-end;
  }

  .chart-svg {
    width: 100%;
    max-height: 140px;
  }

  .journey-globe {
    flex: 1;
    position: relative;
    min-height: 180px;
    background: radial-gradient(circle at center, rgba(99, 102, 241, 0.04) 0%, transparent 70%);
    border-radius: var(--radius-lg);
  }

  .globe-dots {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .globe-dot {
    position: absolute;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .journey-grid-bottom {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .journey-card-sm {
    background: var(--color-bg-section);
    border-radius: var(--radius-xl);
    padding: 32px;
  }

  .journey-sm-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 10px;
  }

  .journey-sm-desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .journey-grid-top,
    .journey-grid-bottom {
      grid-template-columns: 1fr;
    }
  }
</style>
