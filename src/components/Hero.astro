---

---

<section class="hero">
  <div class="hero-bg-shapes">
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
  </div>

  <div class="container hero-inner">
    <!-- Social Proof Badge -->
    <div class="hero-proof-badge">
      <div class="avatar-group">
        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="" class="avatar" />
        <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="" class="avatar" />
        <img src="https://randomuser.me/api/portraits/men/55.jpg" alt="" class="avatar" />
      </div>
      <span class="proof-text">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
        Rated 4.8 by <strong>12.5K Users</strong>
      </span>
    </div>

    <!-- Title -->
    <h1 class="hero-title">
      Manage Your Finance<br/>
      And Banking In <em>One Place</em>
    </h1>

    <!-- Subtitle -->
    <p class="hero-desc">
      Empowering you to take charge of your financial future with intuitive<br class="hide-mobile"/>
      tools and personalized insights.
    </p>

    <!-- CTA Buttons -->
    <div class="hero-cta">
      <a href="/contact/" class="btn btn-primary">GET A FREE TRIAL</a>
      <a href="#" class="btn btn-outline">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--color-dark)"><path d="M5 3l8 5-8 5V3z"/></svg>
        HOW IT WORKS
      </a>
    </div>

    <!-- Phone Mockup -->
    <div class="hero-phone-wrapper">
      <div class="hero-phone">
        <!-- Phone frame -->
        <div class="phone-notch">
          <span class="phone-time">9:41</span>
          <span class="phone-island"></span>
          <span class="phone-icons">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-dark)"><path d="M1 9l2 2c4-4 10-4 14 0l2-2C13 3 7 3 1 9zm4 4l2 2c2.4-2.4 6.6-2.4 9 0l2-2c-3.6-3.6-9.4-3.6-13 0zm4 4l3 3 3-3c-1.6-1.6-4.4-1.6-6 0z"/></svg>
            <svg width="18" height="14" viewBox="0 0 24 16" fill="var(--color-dark)"><rect x="0" y="2" width="20" height="12" rx="2" fill="none" stroke="var(--color-dark)" stroke-width="1.5"/><rect x="21" y="5" width="3" height="6" rx="1" fill="var(--color-dark)"/><rect x="2" y="4" width="12" height="8" rx="1" fill="var(--color-dark)"/></svg>
          </span>
        </div>

        <div class="phone-content">
          <div class="phone-header-row">
            <div class="phone-user">
              <div class="phone-avatar-circle">
                <img src="https://randomuser.me/api/portraits/men/75.jpg" alt="" />
              </div>
              <span>Hi, Norlanda!</span>
            </div>
            <div class="phone-bell">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark)" stroke-width="1.5"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
            </div>
          </div>

          <div class="phone-balance-card">
            <div class="balance-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="var(--color-dark)" stroke-width="1.5"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M2 6h12"/></svg>
            </div>
            <span class="balance-label">Avialable Balance</span>
            <span class="balance-amount">$154,723.00</span>
            <div class="balance-actions">
              <button class="balance-btn topup">Topup <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2v8M2 6h8"/></svg></button>
              <button class="balance-btn withdraw">Withdraw <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6h8M6 2l4 4-4 4"/></svg></button>
            </div>
          </div>

          <div class="phone-activity">
            <div class="activity-header">
              <span>Recent Activity</span>
              <a href="#">See All</a>
            </div>
            <div class="activity-item">
              <div class="activity-icon figma">
                <svg width="14" height="14" viewBox="0 0 14 14"><rect width="14" height="14" rx="3" fill="#f24e1e"/><text x="4" y="11" font-size="9" fill="white" font-weight="bold">F</text></svg>
              </div>
              <div class="activity-info">
                <span class="activity-name">Figma</span>
                <span class="activity-date">12 August 2022</span>
              </div>
              <span class="activity-amount">$20.1</span>
            </div>
            <div class="activity-item">
              <div class="activity-icon netflix">
                <svg width="14" height="14" viewBox="0 0 14 14"><rect width="14" height="14" rx="3" fill="#e50914"/><text x="3" y="11" font-size="9" fill="white" font-weight="bold">N</text></svg>
              </div>
              <div class="activity-info">
                <span class="activity-name">Netflix</span>
                <span class="activity-date">07 August 2022</span>
              </div>
              <span class="activity-amount">$14.1</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating testimonial card -->
      <div class="float-card testimonial-float">
        <div class="float-stars">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#10b981"><rect width="14" height="14" rx="3"/><path d="M7 3l1.3 2.6L11 6l-2 2 .5 2.8L7 9.6 4.5 10.8 5 8l-2-2 2.7-.4z" fill="white"/></svg>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#10b981"><rect width="14" height="14" rx="3"/><path d="M7 3l1.3 2.6L11 6l-2 2 .5 2.8L7 9.6 4.5 10.8 5 8l-2-2 2.7-.4z" fill="white"/></svg>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#10b981"><rect width="14" height="14" rx="3"/><path d="M7 3l1.3 2.6L11 6l-2 2 .5 2.8L7 9.6 4.5 10.8 5 8l-2-2 2.7-.4z" fill="white"/></svg>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#10b981"><rect width="14" height="14" rx="3"/><path d="M7 3l1.3 2.6L11 6l-2 2 .5 2.8L7 9.6 4.5 10.8 5 8l-2-2 2.7-.4z" fill="white"/></svg>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="#10b981"><rect width="14" height="14" rx="3"/><path d="M7 3l1.3 2.6L11 6l-2 2 .5 2.8L7 9.6 4.5 10.8 5 8l-2-2 2.7-.4z" fill="white"/></svg>
        </div>
        <h4 class="float-title">Life-changing app!</h4>
        <p class="float-text">I saved $5,000 in 6 months without even thinking about it.</p>
      </div>

      <!-- Floating check card -->
      <div class="float-card check-float">
        <div class="check-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 180px 0 60px;
    text-align: center;
    overflow: hidden;
    background: var(--color-white);
  }

  .bg-shape {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .bg-shape-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.06) 0%, transparent 70%);
    top: 0;
    left: -150px;
  }

  .bg-shape-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.05) 0%, transparent 70%);
    top: 200px;
    right: -100px;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  /* Social proof badge */
  .hero-proof-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 6px 20px 6px 6px;
    margin-bottom: 36px;
  }

  .avatar-group {
    display: flex;
  }

  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-white);
    margin-left: -8px;
    object-fit: cover;
  }

  .avatar:first-child {
    margin-left: 0;
  }

  .proof-text {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--color-text);
  }

  .proof-text strong {
    color: var(--color-dark);
  }

  /* Title */
  .hero-title {
    font-family: var(--font-primary);
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 600;
    color: var(--color-dark);
    line-height: 1.2;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
  }

  .hero-title em {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: 400;
  }

  /* Desc */
  .hero-desc {
    font-size: 16px;
    color: var(--color-text-light);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  /* CTA */
  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 80px;
  }

  /* Phone Mockup */
  .hero-phone-wrapper {
    position: relative;
    max-width: 340px;
    margin: 0 auto;
  }

  .hero-phone {
    background: var(--color-white);
    border-radius: 40px;
    border: 8px solid #1a1a2e;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.12);
  }

  .phone-notch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px;
    background: var(--color-white);
  }

  .phone-time {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .phone-island {
    width: 80px;
    height: 24px;
    background: #1a1a2e;
    border-radius: 20px;
  }

  .phone-icons {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .phone-content {
    padding: 16px 20px 24px;
  }

  .phone-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .phone-user {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .phone-avatar-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
  }

  .phone-avatar-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .phone-bell {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 50%;
  }

  .phone-balance-card {
    background: #f5f7e8;
    border-radius: var(--radius-lg);
    padding: 20px;
    text-align: left;
    margin-bottom: 20px;
  }

  .balance-icon {
    margin-bottom: 8px;
  }

  .balance-label {
    display: block;
    font-size: 12px;
    color: var(--color-text-light);
    margin-bottom: 4px;
  }

  .balance-amount {
    display: block;
    font-size: 28px;
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -1px;
    margin-bottom: 16px;
  }

  .balance-actions {
    display: flex;
    gap: 10px;
  }

  .balance-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
  }

  .balance-btn.topup {
    background: #4ade80;
    color: var(--color-dark);
  }

  .balance-btn.withdraw {
    background: var(--color-dark);
    color: var(--color-white);
  }

  .phone-activity {
    text-align: left;
  }

  .activity-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .activity-header a {
    font-size: 12px;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .activity-icon svg {
    width: 36px;
    height: 36px;
  }

  .activity-info {
    flex: 1;
  }

  .activity-name {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .activity-date {
    font-size: 11px;
    color: var(--color-text-light);
  }

  .activity-amount {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-dark);
  }

  /* Floating cards */
  .float-card {
    position: absolute;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
    animation: floatAnim 5s ease-in-out infinite;
  }

  .testimonial-float {
    right: -220px;
    top: 40%;
    max-width: 240px;
    text-align: left;
    animation-delay: 0s;
  }

  .check-float {
    left: -80px;
    bottom: 20%;
    padding: 16px;
    border-radius: 50%;
    border: 2px solid #d1fae5;
    animation-delay: 2.5s;
  }

  .float-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 10px;
  }

  .float-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 6px;
  }

  .float-text {
    font-size: 13px;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  @keyframes floatAnim {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 140px 0 40px;
    }

    .hero-cta {
      flex-direction: column;
      margin-bottom: 40px;
    }

    .float-card {
      display: none;
    }

    .hero-title br,
    .hide-mobile {
      display: none;
    }
  }
</style>
