---

<section class="stats-section section">
  <div class="container">
    <div class="stats-top">
      <div class="stats-title-side">
        <h2 class="section-title">Build A Better Financial Future <em>With Finzo</em></h2>
      </div>
      <div class="stats-desc-side">
        <p class="section-desc">Finzo gives you the tools to manage money, grow savings, and achieve your goals.</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card dashed-border">
        <span class="stat-number">4.8/5</span>
        <div class="stat-stars">
          <svg width="16" height="16" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
          <svg width="16" height="16" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
          <svg width="16" height="16" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
          <svg width="16" height="16" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
          <svg width="16" height="16" viewBox="0 0 14 14" fill="#f59e0b"><path d="M7 0l2.2 4.4L14 5.1l-3.5 3.4.8 4.9L7 11.1 2.7 13.4l.8-4.9L0 5.1l4.8-.7z"/></svg>
        </div>
        <p class="stat-desc">Join community transforming the way they manage money.</p>
        <div class="stat-avatars">
          <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="" />
          <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="" />
          <img src="https://randomuser.me/api/portraits/men/55.jpg" alt="" />
        </div>
      </div>

      <div class="stat-card dashed-border">
        <span class="stat-number">420K</span>
        <span class="stat-sub">People Managing Finances Smarter</span>
        <div class="stat-badges">
          <div class="store-badge">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="#fff"><path d="M3 1l2 4.5L3 15l5-3 5 3-2-5.5L13 1 8 4z"/></svg>
            GET IT ON<br/><strong>Google Play</strong>
          </div>
          <div class="store-badge dark">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="#fff"><path d="M7 0C3.1 0 0 3.1 0 7s3.1 7 7 7 7-3.1 7-7S10.9 0 7 0zm2.8 10.5L7 8.6l-2.8 1.9.7-3.2L2.7 5.4l3.3-.3L7 2l1 3.1 3.3.3-2.2 1.9.7 3.2z"/></svg>
            Download on the<br/><strong>App Store</strong>
          </div>
        </div>
      </div>

      <div class="stat-card dashed-border">
        <span class="stat-number">100+</span>
        <span class="stat-sub">Countries Expanded</span>
        <p class="stat-desc">A global community reshaping money management</p>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    background: var(--color-white);
  }

  .stats-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 60px;
    margin-bottom: 60px;
  }

  .stats-title-side {
    max-width: 500px;
  }

  .stats-desc-side {
    max-width: 400px;
    padding-top: 12px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .stat-card {
    border-radius: var(--radius-xl);
    padding: 36px;
  }

  .stat-number {
    display: block;
    font-size: 52px;
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 20px;
  }

  .stat-sub {
    display: block;
    font-size: 15px;
    color: var(--color-text-light);
    margin-bottom: 24px;
  }

  .stat-desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .stat-avatars {
    display: flex;
  }

  .stat-avatars img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid var(--color-white);
    margin-left: -8px;
    object-fit: cover;
  }

  .stat-avatars img:first-child {
    margin-left: 0;
  }

  .stat-badges {
    display: flex;
    gap: 10px;
  }

  .store-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-dark);
    color: var(--color-white);
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    font-size: 10px;
    line-height: 1.3;
  }

  .store-badge strong {
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .stats-top {
      flex-direction: column;
      gap: 20px;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
