---
const leftFeatures = [
  { title: "Real-Time Alerts", desc: "Get instant notifications on transactions, low balances and bill" },
  { title: "Financial Confidence", desc: "Make informed financial decisions with detailed analytics" },
  { title: "Goal Achievement", desc: "Set financial goals and monitor your progress with updates" },
];
const rightFeatures = [
  { title: "Spending Habits", desc: "Analyze your spending patterns and receive tips to cut" },
  { title: "Stress-Free Budgeting", desc: "Set and maintain budgets effortlessly, with automated tracking" },
  { title: "Financial Anxiety", desc: "Feel more in control of your money with tools that simplify" },
];
---

<section class="tools-section section">
  <div class="container">
    <div class="tools-header">
      <h2 class="section-title">Tools For Smarter <em>Management</em></h2>
      <p class="section-desc" style="text-align:center; margin:16px auto 0; max-width:520px;">
        Our platform combines cutting-edge technology with seamless user experience to give you control over your finances
      </p>
    </div>

    <div class="tools-layout">
      <!-- Left Features -->
      <div class="tools-side tools-left">
        {leftFeatures.map((f) => (
          <div class="tool-item tool-item-left">
            <h4 class="tool-title">{f.title}</h4>
            <p class="tool-desc">{f.desc}</p>
            <div class="tool-dot"></div>
          </div>
        ))}
      </div>

      <!-- Center Phone -->
      <div class="tools-center">
        <div class="tools-phone">
          <div class="tp-notch">
            <span class="tp-time">9:41</span>
            <span class="tp-island"></span>
            <span class="tp-icons">
              <svg width="14" height="10" viewBox="0 0 14 10" fill="var(--color-dark)"><path d="M0 7l2 2c3-3 7-3 10 0l2-2C10 3 4 3 0 7z"/></svg>
              <svg width="16" height="10" viewBox="0 0 16 10" fill="var(--color-dark)"><rect x="0" y="1" width="12" height="8" rx="1.5" fill="none" stroke="var(--color-dark)" stroke-width="1"/><rect x="13" y="3" width="2" height="4" rx="0.5" fill="var(--color-dark)"/><rect x="1" y="2" width="8" height="6" rx="0.5" fill="var(--color-dark)"/></svg>
            </span>
          </div>
          <div class="tp-content">
            <div class="tp-user-row">
              <div class="tp-avatar">
                <img src="https://randomuser.me/api/portraits/men/75.jpg" alt="" />
              </div>
              <span class="tp-greeting">Hi, Norlanda!</span>
              <div class="tp-bell">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark)" stroke-width="1.5"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
              </div>
            </div>
            <div class="tp-balance">
              <div class="tp-bal-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="var(--color-dark)" stroke-width="1.2"><rect x="1" y="2.5" width="12" height="9" rx="1.5"/><path d="M1 5h12"/></svg>
              </div>
              <span class="tp-bal-label">Avialable Balance</span>
              <span class="tp-bal-amount">$154,723.00</span>
              <div class="tp-bal-actions">
                <button class="tp-btn green">Topup <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 1v8M1 5h8"/></svg></button>
                <button class="tp-btn dark">Withdraw <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 5h8M5 1l4 4-4 4"/></svg></button>
              </div>
            </div>
            <div class="tp-activity">
              <div class="tp-act-header">
                <span>Recent Activity</span>
                <a href="#">See All</a>
              </div>
              <div class="tp-act-item">
                <div class="tp-act-icon" style="background:#f24e1e;"><span style="color:white;font-weight:bold;font-size:10px;">F</span></div>
                <div class="tp-act-info"><span class="tp-act-name">Figma</span><span class="tp-act-date">12 August 2022</span></div>
                <span class="tp-act-amount">$20.1</span>
              </div>
              <div class="tp-act-item">
                <div class="tp-act-icon" style="background:#e50914;"><span style="color:white;font-weight:bold;font-size:10px;">N</span></div>
                <div class="tp-act-info"><span class="tp-act-name">Netflix</span><span class="tp-act-date">07 August 2022</span></div>
                <span class="tp-act-amount">$14.1</span>
              </div>
            </div>
          </div>
        </div>
        <!-- Dashed connection lines -->
        <svg class="connection-lines" viewBox="0 0 600 500" fill="none">
          <path d="M120 80 Q60 80 60 140 Q60 200 60 260 Q60 380 60 420" stroke="var(--color-border)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
          <path d="M480 80 Q540 80 540 140 Q540 200 540 260 Q540 380 540 420" stroke="var(--color-border)" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
          <!-- Dots on lines -->
          <circle cx="60" cy="100" r="4" fill="var(--color-border)"/>
          <circle cx="60" cy="240" r="4" fill="var(--color-border)"/>
          <circle cx="60" cy="380" r="4" fill="var(--color-border)"/>
          <circle cx="540" cy="100" r="4" fill="var(--color-border)"/>
          <circle cx="540" cy="240" r="4" fill="var(--color-border)"/>
          <circle cx="540" cy="380" r="4" fill="var(--color-border)"/>
        </svg>
      </div>

      <!-- Right Features -->
      <div class="tools-side tools-right">
        {rightFeatures.map((f) => (
          <div class="tool-item tool-item-right">
            <div class="tool-dot"></div>
            <h4 class="tool-title">{f.title}</h4>
            <p class="tool-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tools-section {
    background: var(--color-white);
    overflow: hidden;
  }

  .tools-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .tools-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 20px;
    align-items: center;
  }

  .tools-side {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .tool-item {
    position: relative;
  }

  .tool-item-left {
    text-align: right;
    padding-right: 24px;
  }

  .tool-item-right {
    text-align: left;
    padding-left: 24px;
  }

  .tool-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: 8px;
  }

  .tool-desc {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .tool-dot {
    width: 8px;
    height: 8px;
    background: var(--color-border);
    border-radius: 50%;
    position: absolute;
    top: 8px;
  }

  .tool-item-left .tool-dot {
    right: -4px;
  }

  .tool-item-right .tool-dot {
    left: -4px;
  }

  /* Center phone */
  .tools-center {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .connection-lines {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .tools-phone {
    position: relative;
    z-index: 2;
    width: 260px;
    background: var(--color-white);
    border-radius: 36px;
    border: 6px solid #1a1a2e;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.1);
  }

  .tp-notch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 16px;
  }

  .tp-time {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .tp-island {
    width: 60px;
    height: 18px;
    background: #1a1a2e;
    border-radius: 14px;
  }

  .tp-icons {
    display: flex;
    gap: 3px;
    align-items: center;
  }

  .tp-content {
    padding: 12px 16px 20px;
  }

  .tp-user-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .tp-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    overflow: hidden;
  }

  .tp-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tp-greeting {
    flex: 1;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-dark);
  }

  .tp-bell {
    width: 30px;
    height: 30px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tp-balance {
    background: #f5f7e8;
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 16px;
  }

  .tp-bal-icon {
    margin-bottom: 6px;
  }

  .tp-bal-label {
    display: block;
    font-size: 10px;
    color: var(--color-text-light);
  }

  .tp-bal-amount {
    display: block;
    font-size: 22px;
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -1px;
    margin-bottom: 12px;
  }

  .tp-bal-actions {
    display: flex;
    gap: 8px;
  }

  .tp-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
    border: none;
    cursor: pointer;
  }

  .tp-btn.green {
    background: #4ade80;
    color: var(--color-dark);
  }

  .tp-btn.dark {
    background: var(--color-dark);
    color: white;
  }

  .tp-activity {
    font-size: 12px;
  }

  .tp-act-header {
    display: flex;
    justify-content: space-between;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 10px;
  }

  .tp-act-header a {
    font-size: 10px;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .tp-act-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .tp-act-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tp-act-info {
    flex: 1;
  }

  .tp-act-name {
    display: block;
    font-weight: 600;
    color: var(--color-dark);
    font-size: 12px;
  }

  .tp-act-date {
    font-size: 9px;
    color: var(--color-text-light);
  }

  .tp-act-amount {
    font-weight: 600;
    color: var(--color-dark);
  }

  @media (max-width: 900px) {
    .tools-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .tools-side {
      gap: 32px;
    }

    .tool-item-left,
    .tool-item-right {
      text-align: center;
      padding: 0;
    }

    .tool-dot {
      display: none;
    }

    .connection-lines {
      display: none;
    }

    .tools-center {
      order: -1;
    }
  }
</style>
