---
const apps = [
  { name: "Discord", color: "#5865F2", letter: "D" },
  { name: "Discord", color: "#5865F2", letter: "D" },
  { name: "Inbox", color: "#3b3f8c", letter: "I" },
  { name: "Strava", color: "#1a1a2e", letter: "S" },
  { name: "Figma", color: "#06b6d4", letter: "F" },
  { name: "Teams", color: "#6366f1", letter: "T" },
  { name: "Pagerduty", color: "#10b981", letter: "P" },
  { name: "Pagerduty", color: "#10b981", letter: "P" },
  { name: "Akira", color: "#1a1a2e", letter: "A" },
  { name: "Akira", color: "#1a1a2e", letter: "A" },
  { name: "Slack", color: "#e8d5f5", letter: "S" },
];
---

<section class="integrations section">
  <div class="container">
    <div class="integrations-header">
      <h2 class="section-title">Seamless Integration With<br/><em>Your Favorite Apps</em></h2>
    </div>

    <div class="app-grid">
      {apps.map((app) => (
        <div class="app-icon" style={`background:${app.color};`}>
          <span class="app-letter">{app.letter}</span>
        </div>
      ))}
    </div>

    <div class="integrations-cta">
      <a href="#" class="link-arrow">
        CHECK ALL INTEGRATIONS
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .integrations {
    background: var(--color-white);
  }

  .integrations-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .app-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .app-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s;
  }

  .app-icon:hover {
    transform: scale(1.1);
  }

  .app-letter {
    color: white;
    font-size: 18px;
    font-weight: 700;
  }

  .integrations-cta {
    text-align: center;
  }

  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-dark);
    border-bottom: 1.5px solid var(--color-dark);
    padding-bottom: 4px;
    transition: color 0.2s;
  }

  .link-arrow:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
</style>
