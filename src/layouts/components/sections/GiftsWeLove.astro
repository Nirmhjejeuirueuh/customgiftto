---
/**
 * "Gifts We Love" section - horizontal scrollable product carousel
 * Inspired by Today.com's product picks section
 */

import { Image } from "astro:assets";
import image1 from "@/assets/images/gift/1.webp";
import image2 from "@/assets/images/gift/2.webp";
import image3 from "@/assets/images/gift/3.webp";
import image4 from "@/assets/images/gift/4.webp";
import image5 from "@/assets/images/gift/5.webp";

const products = [
  {
    name: "Personalized Leather Journal",
    tagline: "For the writer who loves a personal touch.",
    price: "$29.99",
    store: "ETSY",
    image: image1,
  },
  {
    name: "Custom Star Map Print",
    tagline: "A memorable night sky, frozen in time.",
    price: "$39.95",
    store: "CUSTOM PRINTS",
    image: image2,
  },
  {
    name: "Engraved Wooden Watch",
    tagline: "Timeless style meets personal flair.",
    price: "$54.99",
    store: "AMAZON",
    image: image3,
  },
  {
    name: "Monogrammed Tote Bag",
    tagline: "Carry your style, carry your name.",
    price: "$24.99",
    store: "NORDSTROM",
    image: image4,
  },
  {
    name: "Custom Photo Puzzle",
    tagline: "Turn memories into a fun challenge.",
    price: "$19.99",
    store: "SHUTTERFLY",
    image: image5,
  },
];
---

<section class="bg-theme-light py-10 md:py-14">
  <div class="container">
    <h2 class="mb-2 text-4xl font-normal italic md:text-5xl" style="font-family: 'Georgia', 'Times New Roman', serif;">
      <span class="relative inline-block">
        Gifts We Love
        <span class="absolute -bottom-1 left-0 h-2 w-full bg-secondary/40"></span>
      </span>
    </h2>
    <p class="mb-8 text-sm text-gray-500">
      We earn a commission on purchases through these links.
    </p>

    <!-- Product Carousel -->
    <div class="scrollbar-hide -mx-4 flex gap-5 overflow-x-auto px-4 pb-4">
      {products.map((product) => (
        <div class="min-w-[200px] max-w-[220px] flex-shrink-0">
          <div class="group mb-3 aspect-square overflow-hidden rounded-lg bg-white p-4 shadow-sm">
            <Image
              src={product.image}
              alt={product.name}
              class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
            />
          </div>
          <h3 class="text-sm font-bold leading-tight text-gray-900">{product.name}</h3>
          <p class="mt-1 text-xs text-gray-500">{product.tagline}</p>
          <div class="mt-2 flex items-baseline gap-2">
            <span class="text-lg font-bold text-primary">{product.price}</span>
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">{product.store}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
