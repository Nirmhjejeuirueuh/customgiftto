---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import { getEntryCTM } from "@/lib/contentParser.astro";
import GiftHero from "@/components/sections/GiftHero.astro";
import GiftsWeLove from "@/components/sections/GiftsWeLove.astro";
import GiftCategorySection from "@/components/sections/GiftCategorySection.astro";
import MoreGiftGuides from "@/components/sections/MoreGiftGuides.astro";
import LatestArticles from "@/components/sections/LatestArticles.astro";
import CallToAction from "@/components/sections/CallToAction.astro";

export function getStaticPaths() {
  return generatePaths();
}

const homepage = await getEntryCTM("homepage", "-index", Astro.currentLocale);
---

<Base {...homepage.data} homepage={true} hasGradientShape={false} sectionSpacing="md">
  <!-- Hero with featured article + nav links -->
  <GiftHero />

  <!-- Gifts We Love - Product picks carousel -->
  <GiftsWeLove />

  <!-- Shop for gifts by age -->
  <GiftCategorySection
    title="By Age"
    subtitle="They're Not So Little Anymore! Shop 41 Gifts for 4-Year-Olds Growing into Big Kids"
    category="By Age"
    links={[
      { name: "1-YEAR-OLDS", url: "/blog/" },
      { name: "3-YEAR-OLDS", url: "/blog/" },
      { name: "4-YEAR-OLDS", url: "/blog/" },
      { name: "10-YEAR-OLDS", url: "/blog/" },
      { name: "21-YEAR-OLDS", url: "/blog/" }
    ]}
    limit={5}
  />

  <!-- Gifts for him -->
  <GiftCategorySection
    title="Gifts for Him"
    subtitle="36 Gifts for Boyfriends They'll Love (Almost) As Much As You"
    category="Gifts for Him"
    links={[
      { name: "HIM", url: "/blog/" },
      { name: "BOYFRIENDS", url: "/blog/" },
      { name: "DADS", url: "/blog/" },
      { name: "GRANDPAS", url: "/blog/" }
    ]}
    limit={5}
    class="bg-theme-light"
  />

  <!-- By Recipient -->
  <GiftCategorySection
    title="By Recipient"
    subtitle="Stumped on What To Get Grandma? Thoughtful Gifts She'll Love"
    category="By Recipient"
    links={[
      { name: "HER", url: "/blog/" },
      { name: "MOMS", url: "/blog/" },
      { name: "GRANDMAS", url: "/blog/" },
      { name: "KIDS", url: "/blog/" }
    ]}
    limit={5}
  />

  <!-- Moments worth celebrating -->
  <GiftCategorySection
    title="Moments worth celebrating"
    subtitle="The Best High School Graduation Gifts of 2026: Dorm Essentials, Tech & Keepsakes"
    category="Graduation"
    links={[
      { name: "BIRTHDAYS", url: "/blog/" },
      { name: "WEDDINGS", url: "/blog/" },
      { name: "GRADUATIONS", url: "/blog/" },
      { name: "ANNIVERSARIES", url: "/blog/" }
    ]}
    limit={5}
    class="bg-theme-light"
  />

  <!-- More gift guides carousel -->
  <MoreGiftGuides />

  <!-- Latest Articles list -->
  <LatestArticles />

  <!-- Call to Action / Newsletter -->
  <CallToAction />
</Base>
